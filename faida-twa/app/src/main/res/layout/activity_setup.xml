<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F5F7">

    <!-- Top blue header — matches Faida web app navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/faida_blue"
        android:padding="24dp">

        <!-- Logo mark: white circle with F -->
        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="F"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/faida_blue"
            android:gravity="center"
            android:background="@drawable/logo_circle"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Faida"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestion de votre business airtime"
            android:textSize="13sp"
            android:textColor="#C8D8F8" />

    </LinearLayout>

    <!-- White card -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connexion"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entrez votre code personnel pour activer l'application"
                        android:textSize="13sp"
                        android:textColor="#8898AA"
                        android:layout_marginBottom="24dp" />

                    <!-- Code API -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CODE API"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8898AA"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etApiToken"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Collez votre code ici"
                        android:inputType="text"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Où trouver votre code → Faida web → Profil → Code API → Copier"
                        android:textSize="11sp"
                        android:textColor="#8898AA"
                        android:layout_marginBottom="28dp" />

                    <Button
                        android:id="@+id/btnSave"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Activer Faida"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/faida_blue"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Footer note -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:text="Serveur: faida-app.onrender.com"
                android:textSize="11sp"
                android:textColor="#AAAAAA" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
