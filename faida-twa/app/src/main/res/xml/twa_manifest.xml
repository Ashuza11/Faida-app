<?xml version="1.0" encoding="utf-8"?>
<!--
  TWA configuration.
  Set packageId to com.faida.twa — must match applicationId in build.gradle.
  Set hostName to your Render / custom domain WITHOUT https:// prefix.
  Set startUrl to "/" — Chrome will open https://<hostName>/ in full screen.
  launchHandlerClientMode: navigate-existing means SMS deep-links won't open extra tabs.
-->
<trusted-web-activity-config
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:hostName="faida-app.onrender.com"
    android:startUrl="/"
    android:statusBarColor="@color/faida_blue"
    android:navigationBarColor="@color/white"
    android:splashScreenBackgroundColor="@color/faida_blue"
    android:splashScreenFadeOutDuration="300" />
